#!/usr/bin/env bash
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TARGET_DIR="${EMMI_SKILLS_HOME:-$HOME/.claude/skills}"
TARGET="$TARGET_DIR/emmi"
mkdir -p "$TARGET_DIR"
if [[ -e "$TARGET" && ! -L "$TARGET" ]]; then
  echo "Refusing to overwrite non-symlink: $TARGET" >&2
  exit 1
fi
rm -f "$TARGET"
ln -sf "$REPO_ROOT" "$TARGET"
echo "Linked $TARGET -> $REPO_ROOT"

# Sub-skills — each gets its own entry so they're available as slash commands
SUB_SKILLS=(
  analytics-dev architect-dev browse deployment-dev efficiency-dev ferdig-ferdig
  iterative-process mobile-dev monorepo-dev product-manager team-manager
  test ui-ux web-dev
)
for sub in "${SUB_SKILLS[@]}"; do
  dest="$TARGET_DIR/$sub"
  src="$REPO_ROOT/$sub"
  rm -rf "$dest"
  ln -sf "$src" "$dest"
  echo "Linked $dest -> $src"
done
